# Скопируйте в .env и подставьте свои значения.

# SQLite (локально по умолчанию backend/domkofe.db; в Docker задайте через compose)
# DATABASE_URL=sqlite+aiosqlite:///./domkofe.db

# JWT для админки
SECRET_KEY=your_jwt_secret_min_32_chars_recommended

# Первый администратор (seed создаёт запись, если таблица пуста)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Порт nginx на хосте
NGINX_PORT=80
